{
  "name": "dzinerhub-autopublisher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "stories": "tsx src/stories.ts",
    "inspiration": "tsx src/inspiration.ts",
    "dry": "DRY_RUN=true tsx src/index.ts",
    "refresh:draft-screenshots": "tsx src/refresh-draft-screenshots.ts",
    "refresh:ai-comments": "tsx src/refresh-ai-comments.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "framer-api": "^0.1.17",
    "playwright": "^1.50.1",
    "sharp": "^0.35.2",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  }
}
